# Server
SERVER_PORT=8080
SERVER_MODE=debug

# Database
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=employment
DB_PASSWORD=employment123
DB_NAME=employment_db
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Shanghai
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30m

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=redis123
REDIS_DB=0
REDIS_POOL_SIZE=20

# JWT (production: use RS256 with file paths)
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h

# Encryption
AES_KEY=change-me-32-bytes-key-here!!!!
PEPPER_SECRET=change-me-pepper-secret-32chars!

# Upload
UPLOAD_MAX_SIZE_MB=10
UPLOAD_PATH=./data/uploads

# Log
LOG_LEVEL=info
LOG_OUTPUT=stdout
